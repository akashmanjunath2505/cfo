# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: Neon PostgreSQL connection string.
DATABASE_URL="postgresql://neondb_owner:npg_Ssog1aLZCGE2@ep-little-bread-aiboengh-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require"

# STRIPE_SECRET_KEY: Stripe secret key for payments.
STRIPE_SECRET_KEY=""

# VITE_STRIPE_PUBLISHABLE_KEY: Stripe publishable key for the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=""

# CFO_OWNER_TOKEN: shared token expected in x-owner-token header for write actions.
CFO_OWNER_TOKEN=""

# VITE_OWNER_TOKEN: optional frontend token for owner dashboard auth headers.
VITE_OWNER_TOKEN=""

# CFO_AUTONOMY_ENABLED: enables autonomous execution of actions.
CFO_AUTONOMY_ENABLED="true"

# CFO_ACTIONS_KILL_SWITCH: emergency global stop for autonomous actions.
CFO_ACTIONS_KILL_SWITCH="false"

# CFO_ALLOWED_ACTIONS: comma-separated allowlist for autonomous action types.
CFO_ALLOWED_ACTIONS="allocate_research_budget,activate_treasury_strategy,respond_approval,create_investor,run_simulation"

# CFO_AUDIT_SLACK_ENABLED: controls audit/action Slack notifications.
CFO_AUDIT_SLACK_ENABLED="true"

# CFO_MAX_SINGLE_ALLOCATION_USD: hard per-action allocation cap.
CFO_MAX_SINGLE_ALLOCATION_USD="25000"

# CFO_DISABLED_DOMAINS: comma-separated disabled domains (finance,outreach,messaging,planning,crm,payments).
CFO_DISABLED_DOMAINS=""

# Savings-share billing configuration.
CFO_FEE_PERCENTAGE="5"
CFO_MIN_MONTHLY_FEE_USD="0"
CFO_MAX_MONTHLY_FEE_USD="10000"
CFO_HUMAN_HOURLY_RATE="150"
STRIPE_CUSTOMER_ID=""

# Optional external integration webhooks for autonomous operations.
CFO_EMAIL_WEBHOOK_URL=""
CFO_MESSAGING_WEBHOOK_URL=""
CFO_CALENDAR_WEBHOOK_URL=""
CFO_CRM_WEBHOOK_URL=""
